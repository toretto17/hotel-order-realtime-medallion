# Aiven Kafka — single place for connection details
# Copy this file to .env and fill in your values. Never commit .env (it's in .gitignore).
# If you see "bad certificate" when running make test-kafka, use SSL (not SASL_SSL) — see below.

# --- Required: bootstrap (from Aiven Console → your Kafka service → Connection information) ---
KAFKA_BOOTSTRAP_SERVERS=order-medallion-kafka-realtime-order-medallion.d.aivencloud.com:19413

# --- Security: use SSL + client cert when Aiven SASL tab is disabled (avoids "bad certificate" error) ---
KAFKA_SECURITY_PROTOCOL=SSL

# --- Option A: Client certificate (recommended for Aiven when SASL tab not available) ---
# Copy ca.pem, service.cert, service.key from Aiven (Connection information → Certificates) into project certs/.
KAFKA_SSL_CA_LOCATION=/Users/rahulshah/realtime-order-medallion/certs/ca.pem
KAFKA_SSL_CERT_LOCATION=/Users/rahulshah/realtime-order-medallion/certs/service.cert
KAFKA_SSL_KEY_LOCATION=/Users/rahulshah/realtime-order-medallion/certs/service.key
# KAFKA_SSL_KEY_PASSWORD=   # only if service.key is password-protected

# --- Option B: SASL (only if Aiven shows Connection information → SASL tab for Kafka) ---
# Schema Registry username/password are NOT for Kafka — do not use them here.
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=SCRAM-SHA-256
# KAFKA_SASL_USERNAME=avnadmin
# KAFKA_SASL_PASSWORD=your-kafka-sasl-password-from-console

# --- For Render (hosted website): no file paths — use cert/key contents as env vars (see docs/RENDER_WEBSITE_HOSTING_STEP_BY_STEP.md) ---
# KAFKA_SSL_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# KAFKA_SSL_CERT_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# KAFKA_SSL_KEY_CERT="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# --- Pipeline (Bronze/Silver/Gold) ---
KAFKA_TOPIC=orders
BASE_PATH=/tmp/medallion
